 logger = init_logger(__name__)
 
+# --- gdn_hip: native HIP GDN ops (gfx1201) ---------------------------------------------------
+# When VLLM_GDN_HIP=1 the Qwen GDN linear-attention compute (conv1d + gated-delta-rule +
+# gated RMSNorm) is routed through torch.ops.gdn_hip.* instead of the fla-Triton kernels, so the
+# layer never JIT/autotunes a Triton kernel (mirrors the zaya_cca integration). The ops are
+# AOT-compiled once for gfx1201 and registered (with fake/meta impls) on import. fp32 at the op
+# boundary: the recurrent state (conv_state + ssm_state) must be fp32 — forced in
+# MambaStateDtypeCalculator.gated_delta_net_state_dtype when this flag is on.
+import os as _os
+
+VLLM_GDN_HIP = _os.environ.get("VLLM_GDN_HIP", "0") == "1"
+# WMMA matrix-core chunked prefill is the default GDN prefill when gdn_hip is on (4.8-5.9x faster
+# than the scalar recurrent prefill); set VLLM_GDN_HIP_RECURRENT_ONLY=1 to force the recurrent path.
+VLLM_GDN_HIP_RECURRENT_ONLY = _os.environ.get("VLLM_GDN_HIP_RECURRENT_ONLY", "0") == "1"
+
+
+def _gdn_select_prefill(layer):
+    """Pick the GDN prefill op: WMMA matrix-core chunked prefill (4.8-5.9x faster) for 128-dim
+    Qwen3.5/3.6 GDN heads, else the scalar recurrent prefill (also forced by
+    VLLM_GDN_HIP_RECURRENT_ONLY=1). Both share the fp32 op boundary and the same state cache."""
+    if (not VLLM_GDN_HIP_RECURRENT_ONLY
+            and getattr(layer, "head_k_dim", 0) == 128
+            and getattr(layer, "head_v_dim", 0) == 128):
+        return torch.ops.gdn_hip.gdn_prefill_wmma
+    return torch.ops.gdn_hip.gdn_prefill
+_GDN_HIP = None
+if VLLM_GDN_HIP:
+    try:
+        from vllm.model_executor.layers.mamba.gdn_hip import op as _GDN_HIP  # noqa: F401
+
+        logger.info_once("Qwen GDN: native HIP gdn_hip ops ENABLED (no Triton JIT on the GDN path).")
+    except Exception:  # pragma: no cover - build/load failure -> fall back to fla-Triton
+        _GDN_HIP = None
+        logger.warning(
+            "VLLM_GDN_HIP=1 but gdn_hip failed to import; falling back to the fla-Triton GDN path.",
+            exc_info=True,
+        )
+
 
