+        # --- Heterogeneous TP: proportional MoE intermediate split (gfx1201 64:56).
+        # No-op unless VLLM_TP_CU_WEIGHTS is set. align = HET_ALIGN_FLOOR (128): a
+        # multiple of every common AWQ group (16/32/64/128) and the kernel tiles, so
+        # the per-partition size stays valid AND matches the het offsets the expert
+        # loaders (_het_moe_shard) compute with the SAME floor. The full (logical)
+        # intermediate is stashed for those loaders -- it can't be recovered from the
+        # per-partition size once the split is uneven.
+        self._het_moe_intermediate_size = intermediate_size
+        from vllm.distributed.het_tp import (
+            HET_ALIGN_FLOOR, get_cu_weights, het_active, partition_sizes)
+        if het_active(self.tp_size) and intermediate_size % HET_ALIGN_FLOOR == 0:
+            intermediate_size_per_partition = partition_sizes(
+                intermediate_size, get_cu_weights(self.tp_size),
+                align=HET_ALIGN_FLOOR)[self.moe_parallel_config.tp_rank]
+        else:
+            assert intermediate_size % self.tp_size == 0
+            intermediate_size_per_partition = intermediate_size // self.tp_size
         self.renormalize = renormalize
 
         # TODO(bnell): these attributes are only used by monolithic kernels.
