+    def _het_moe_shard(self, axis_total: int, tp_rank: int, tp_size: int):
+        """``(start, per_rank)`` along the intermediate (shard) axis, in the tensor's
+        own units. Proportional 64:56 when ``VLLM_TP_CU_WEIGHTS`` is set, else the
+        stock even split. Uses ``HET_ALIGN_FLOOR`` (128) so the offsets match the
+        per-partition sizing computed in ``__init__``. ``axis_total`` is
+        ``loaded_weight.shape[shard_dim]`` (axis units: packed/grouped/plain); the
+        full *logical* intermediate stashed in ``__init__`` lets ``het_axis_shard``
+        convert logical apportionment to those axis units."""
+        from vllm.distributed.het_tp import (
+            HET_ALIGN_FLOOR, het_active, het_axis_shard)
+        if not het_active(tp_size):
+            per = axis_total // tp_size
+            return per * tp_rank, per
+        return het_axis_shard(self._het_moe_intermediate_size, HET_ALIGN_FLOOR,
+                              axis_total, tp_rank, tp_size)
+
