# Local env + secrets
.env

# Fetched / built wheels (live in a GitHub Release, not git)
wheels/
*.whl

# Persistent caches (compose mounts these by default)
.triton-cache/
.vllm-cache/
.hf-cache/

# Build artifacts from the W4A8 kernel package
w4a8_fp8_wmma/build/
w4a8_fp8_wmma/**/*.so
w4a8_fp8_wmma/**/*.o
**/__pycache__/
*.egg-info/

# profiling sweep artifacts (traces are large; keep scripts, prune traces)
profiling/triton-cache/
profiling/**/cells/
profiling/**/*.pt.trace.json.gz
profiling/

.triton-cache-combined/
.triton-cache-old/
.triton-cache-combined-sweep/
.triton-cache*
.vllm-cache*
# gpu-lease runtime lock/label files (ephemeral; see scripts/gpu-lease.sh)
.gpu-locks/

# --- Titans / CAM experiment (titans/) ---
# Vendored vLLM source snapshot + root scratch logs (reproducible, large)
.vllm-src/
_titans_*.log
# Large model dumps (enwik8 training checkpoints incl. >100MB files GitHub rejects)
titans/checkpoints-enwik8/
titans/checkpoints-enwik8-smoke/
# Nested reference clone (lucidrains titans-pytorch — has its own .git)
titans/ref-titans-pytorch/
# Heavy derived weight artifacts (the v0 memory + per-base translator cards, 50-80MB each)
titans/warmstart/ckpt/cam_v0_L24.pt
titans/warmstart/ckpt/translator_*.pt
# Run logs (transient; conclusions live in the *.md results files)
titans/warmstart/logs/
# Keep the SMALL validated artifacts: warmstart/ckpt/probe/*, warmstart/ckpt/atlas/*
