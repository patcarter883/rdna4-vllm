# Keep the build context small. The Dockerfiles only need patches/, w4a8_fp8_wmma/
# (sources), scripts/, and the compose/env files — never the profiling artifacts or git.
.git
.github
profiling/
prof/
*.log
.claude/
# Persistent caches are root-owned (created by container bind-mounts) and break build-context
# scanning ("no permission to read"); huge and never belong in an image.
.triton-cache*
.vllm-cache*
.hf-cache
# build artifacts (the kernel is (re)built in-image; never ship stale host .so/build dirs)
**/__pycache__/
**/*.so
**/*.o
**/build/
**/*.egg-info/
**/.pytest_cache/

# client-side venvs (e.g. rsa/.venv) — never ship into an image build context
**/.venv/
