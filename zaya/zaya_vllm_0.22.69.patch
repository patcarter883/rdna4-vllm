+    @classmethod
+    def cca_state_copy_func(cls):
+        # Both CCA states (conv + prev_hs) are stored per-spec-position in
+        # separate block slots, so both roll back by block-index (whole-block
+        # copy) — i.e. get_temporal_copy_spec semantics. The fused align
+        # postprocess only recognizes get_conv_copy_spec / get_temporal_copy_spec;
+        # using get_temporal_copy_spec for the conv state too (conv_width treated
+        # as 0 → block-index copy) matches our per-slot layout.
+        return (get_temporal_copy_spec, get_temporal_copy_spec)
+
     @classmethod
     def gated_delta_net_state_copy_func(cls):
         return (get_conv_copy_spec, get_temporal_copy_spec)
