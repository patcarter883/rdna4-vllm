+def get_cca_conv_copy_spec(
+    state: torch.Tensor,
+    block_ids: list[int],
+    cur_block_idx: int,
+    num_accepted_tokens: int,
+) -> MambaCopySpec:
+    """Return a MambaCopySpec for the CCA conv state of the last accepted token.
+
+    CCA stores the conv window for spec-decode position j in a separate block
+    slot (like the temporal state), so the rollback picks the block at the
+    accepted position rather than slicing columns.
+    """
+    src_block_id = block_ids[cur_block_idx + num_accepted_tokens - 1]
+    src_state = state[src_block_id]
+    return MambaCopySpec(
+        start_addr=src_state.data_ptr(), num_elements=src_state.numel()
+    )
+
