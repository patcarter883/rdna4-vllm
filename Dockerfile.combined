# syntax=docker/dockerfile:1
#
# Combined image: the collaborator's tuned-attention vLLM (tcclaviger/vllm22:dev)
# + our W4A8-FP8-WMMA kernel layered on top.
#
#   their base  -> RDNA4 attention done: triton_attn default on gfx1201, fp8-KV native
#                  gate, fp8 dequant scale-fold, startup autotuner. Python 3.12 venv at
#                  /app/.venv, torch 2.10.0, system ROCm 7.2.1 (amdclang 22) at
#                  /opt/rocm-7.2.1, vLLM 0.22.69 (editable at /app/vllm).
#   our layer   -> the W4A8 dense (v5/v10/v11) + grouped-MoE (v6) FP8-WMMA kernel,
#                  built in-image so its ABI matches the base's torch (cp312).
#
# SOURCE OF TRUTH: the W4A8 kernel now lives IN this repo at w4a8_fp8_wmma/ — the single
# canonical copy (see memory: w4a8-single-source-of-truth). It is COPYed straight from the repo
# and (re)built in-image for gfx1201 / ROCm-7.2.1, so the .so always matches the base's torch.
# Build (no GPU needed — the HIP kernel cross-compiles):
#
#   docker build -f Dockerfile.combined -t vllm22-w4a8:combined .
#
# (docker-compose.yml builds it by default.)
#
# Run: the W4A8 kernel auto-engages via the vllm.general_plugins entry point in every
# EngineCore worker; disable at runtime (no rebuild) with VLLM_ROCM_USE_W4A8_FP8_WMMA=0.
# Mount a persistent Triton cache — both Qwen3.6 variants are GDN hybrids and pay the FLA-GDN
# cold compile + the base's attention startup autotune; cache makes it one-time.

# Base image is PINNED BY DIGEST, not by the moving `:dev` tag. The collaborator's
# `tcclaviger/vllm22:dev` is a mutable tag that can shift under us — and RFP458, the tuned
# attention, and the whole `/app/vllm` tree our patches target all live in this base, so a
# silent tag move would bitrot every patch and can break the W4A8 ABI (torch bump) with no
# detection. The digest below was the `:dev` snapshot as of 2026-06-18 (RXF quant +
# auto_gptq_qzeros). Conflict-checked against our patches before bumping: torch/py/triton
# byte-identical (no W4A8 ABI break, Triton cache stays valid), het-TP + ZAYA + moe_wna16 sed
# all apply clean, and the changes vs the prior 2026-06-14 base are additive / off our path.
#   Bump procedure: `docker pull tcclaviger/vllm22:dev` then
#   `docker inspect tcclaviger/vllm22:dev --format '{{index .RepoDigests 0}}'`, paste the new
#   `name@sha256:...` here, and re-run the in-image import check (CONTRIBUTING.md) before relying on it.
# Override with `--build-arg BASE_IMAGE=...` (or COMBINED_BASE_IMAGE in .env) to test a newer base.
ARG BASE_IMAGE=tcclaviger/vllm22@sha256:ad046fde24d9233e72790222cbac3fc24f7e47a0d28e3089c2a383422890d67a
FROM ${BASE_IMAGE}

ARG GPU_ARCHS=gfx1201
ENV ROCM_HOME=/opt/rocm-7.2.1 \
    GPU_ARCHS=${GPU_ARCHS} \
    MAX_JOBS=16

# --- 1. Build + install the W4A8 kernel from the in-repo source ---
# w4a8_fp8_wmma/ is the single canonical copy. Clean any stray build/ + *.so first
# (.dockerignore already excludes them, but be defensive — never reuse a host .so; we rebuild
# for gfx1201 / ROCm-7.2.1). ld.lld lives under the system ROCm llvm bin; GPU_ARCHS keeps the
# offload list off the display iGPU. The source tree is removed after install so the import
# check resolves the INSTALLED package (sys.path source-shadow trap).
COPY w4a8_fp8_wmma/ /opt/w4a8_fp8_wmma
RUN set -eu; \
    . /app/.venv/bin/activate; \
    export PATH="/opt/rocm-7.2.1/lib/llvm/bin:/opt/rocm-7.2.1/bin:${PATH}"; \
    cd /opt/w4a8_fp8_wmma; \
    rm -rf build *.egg-info; find . -name '*.so' -delete; \
    pip install . --no-build-isolation --no-deps; \
    cd /; rm -rf /opt/w4a8_fp8_wmma; \
    python -c "import w4a8_fp8_wmma, w4a8_fp8_wmma._C; print('[combined] W4A8 import OK ::', w4a8_fp8_wmma.__file__)"

# --- 2. Surgical moe_wna16 tp_size fix (RoutedExperts hazard, DIARY Blocker 2) ---
# Their moe_wna16 reads `layer.tp_size` directly AND has diverged from our whole-file patch
# (it added a MoEActivation.SILU assertion), so apply ONLY the tp_size fallback via sed on the
# two unambiguous occurrences — idempotent (the replacement holds `layer.moe_config.tp_size`,
# not the literal `layer.tp_size`) and preserves their other changes. Locate via `find` (NOT
# `import vllm...`, which prints Triton/INFO logs to stdout and would corrupt the captured path).
RUN set -eu; \
    MW="$(find /app/vllm /opt /usr -path '*vllm/model_executor/layers/quantization/moe_wna16.py' -type f 2>/dev/null | grep -v '\.orig$' | head -1)"; \
    test -n "$MW" || { echo "moe_wna16.py not found"; exit 1; }; \
    cp "$MW" "${MW}.orig"; \
    sed -i 's/layer\.tp_size/(getattr(layer, "tp_size", None) or layer.moe_config.tp_size)/g' "$MW"; \
    python3 -c "import ast; ast.parse(open('${MW}').read())"; \
    grep -q 'getattr(layer, "tp_size"' "$MW"; \
    echo "[combined] moe_wna16 tp_size fallback applied -> $MW"

# --- 2b. (optional) Heterogeneous-TP proportional sharding — 64:56 for a 9070 XT + 9070 ---
# Splits the FFN/MoE intermediate proportional to CU counts so the big card stops spin-waiting
# at the all-reduce barrier (the rank1 COMM=61% sync bubble). Gated OFF by default; lights up
# once the het-TP agent drops the re-targeted (vLLM 0.22.69!) source diff into
# patches/het_tp_vllm.patch. See patches/HET_TP_HANDOFF.md. Build: --build-arg WITH_HET_TP=1;
# runtime needs VLLM_TP_CU_WEIGHTS="64,56" (docker-compose.yml).
ARG WITH_HET_TP=1
COPY patches/het_tp.py patches/het_tp_vllm.patch /tmp/hettp/
RUN set -eu; \
    if [ "$WITH_HET_TP" = "1" ]; then \
      grep -q '^@@' /tmp/hettp/het_tp_vllm.patch || { \
        echo "ERROR: patches/het_tp_vllm.patch is still a placeholder — the het-TP agent must drop"; \
        echo "       the re-targeted vLLM 0.22.69 unified diff here. See patches/HET_TP_HANDOFF.md."; \
        exit 1; }; \
      install -D /tmp/hettp/het_tp.py /app/vllm/vllm/distributed/het_tp.py; \
      cd /app/vllm && patch -p1 < /tmp/hettp/het_tp_vllm.patch; \
      python3 -c "import ast; ast.parse(open('/app/vllm/vllm/model_executor/layers/linear.py').read())"; \
      echo "[combined] het-TP applied (set VLLM_TP_CU_WEIGHTS at runtime)"; \
    else echo "[combined] het-TP slot present but disabled (build --build-arg WITH_HET_TP=1 to enable)"; fi; \
    rm -rf /tmp/hettp

# --- 3. W4A8 defaults (all overridable at runtime via -e / compose; no rebuild to toggle) ---
# MOE_KERNEL=wmma is the (tiled) grouped WMMA kernel that executes on the MoE path; it is
# also the built-in default, so this ENV is documentation. The numeric MOE_VERSION was
# de-numbered to names (wmma|scalar|gemv); the old var now HARD-ERRORS at boot if set, so
# it must not be baked here (A-residence, formerly v5-vs-v6, is the VLLM_W4A8_MOE_A_IN_LDS knob).
# Do NOT bake VLLM_ROCM_W4A8_FORCE — W4A8 is a *decode-regime* win and loses at mid/large/prefill,
# so leave the adaptive crossover dispatch in charge; force per-run if needed.
ENV VLLM_ROCM_USE_W4A8_FP8_WMMA=1 \
    VLLM_ROCM_W4A8_FP8_WMMA_MOE=1 \
    VLLM_ROCM_W4A8_FP8_WMMA_MOE_KERNEL=wmma

# --- 4. (optional) ZAYA1-8B + CCA support — the second model, folded in ---
# Was a derived image (Dockerfile.zaya); now a gated step so ONE combined image serves both the
# 35B W4A8 path and ZAYA1-8B. Three additive pieces (mirroring W4A8/het-TP): the overlay
# model/config/parser/backend files, the fused CCA decode/prefill/mixed HIP kernel (cross-compiled
# in-image — no GPU), and ~9 registration hooks (zaya_vllm_0.22.69.patch). The only two hunks that
# touch shared files are no-ops for the 35B path: a generic torch.compile-safety guard in
# fused_moe.py and a `vllm::cca` splitting_ops entry (that op never exists for non-ZAYA models).
# Default ON so the single image serves ZAYA out of the box; build --build-arg WITH_ZAYA=0 for a
# W4A8-only image. Toggle the fused kernel at runtime (no rebuild): ZAYA_CCA_HIP=0 -> eager CCA.
ARG WITH_ZAYA=1
ENV ZAYA_CCA_HIP=1
COPY zaya/ /tmp/zaya/
RUN set -eu; \
    if [ "$WITH_ZAYA" = "1" ]; then \
      . /app/.venv/bin/activate; \
      export PATH="/opt/rocm-7.2.1/lib/llvm/bin:/opt/rocm-7.2.1/bin:${PATH}"; \
      VV=/app/vllm/vllm; \
      cp -r /tmp/zaya/overlay/vllm/. "$VV"/; \
      cp -r /tmp/zaya/cca_hip "$VV"/model_executor/layers/mamba/; \
      cd "$VV"/model_executor/layers/mamba/cca_hip; \
        rm -rf build *.egg-info; find . -name '*.so' -delete; find . -name '*_hip.*' -delete; \
        GPU_ARCHS=gfx1201 python setup.py build_ext --inplace; \
        python -c "import torch, glob; torch.ops.load_library(glob.glob('zaya_cca_C*.so')[0]); print('[combined] CCA kernel build + load OK')"; \
      cd /app/vllm; patch -p1 < /tmp/zaya/zaya_vllm_0.22.69.patch; \
      python -c 'import ast; roots=["/app/vllm/vllm/model_executor/models/zaya.py", "/app/vllm/vllm/model_executor/layers/mamba/cca.py", "/app/vllm/vllm/model_executor/layers/mamba/mamba_utils.py", "/app/vllm/vllm/config/model.py", "/app/vllm/vllm/model_executor/layers/fused_moe/fused_moe.py"]; [ast.parse(open(f).read()) for f in roots]; print("[combined] ZAYA overlay + patched files parse OK")'; \
      echo "[combined] ZAYA1-8B + CCA applied"; \
    else echo "[combined] ZAYA slot present but disabled (build --build-arg WITH_ZAYA=1 to enable)"; fi; \
    rm -rf /tmp/zaya

# --- 5. (optional) Native HIP GDN kernels (gdn_hip) — kill the Triton JIT on the Qwen GDN path ---
# Routes Qwen3-Next / Qwen3.5 / Qwen3.6 Gated-Delta-Net linear-attention (conv1d + gated-delta-rule
# + gated RMSNorm) through AOT-compiled torch.ops.gdn_hip.* instead of the fla-Triton kernels, so
# the GDN layer never JIT/autotunes a Triton kernel again (same motivation as the zaya_cca step).
# Three additive pieces, mirroring ZAYA/het-TP: the gdn_hip package (cross-compiled in-image — no
# GPU), a 1-method patch to qwen_gdn_linear_attn.py (gated on VLLM_GDN_HIP=1 at runtime), and a
# 1-branch patch to mamba_utils.py forcing the GDN conv+ssm state fp32 under the same flag. Default
# build-arg OFF (kernel newly integrated — flip --build-arg WITH_GDN_HIP=1 once validated); and the
# runtime is itself gated by VLLM_GDN_HIP (default 0), so even a built image is a no-op until the
# env is set. Spec-decode keeps the fla-Triton path (gdn_hip is single-token decode / varlen
# recurrent prefill only); the recurrent prefill trades long-context throughput for zero compiles.
ARG WITH_GDN_HIP=0
COPY gdn_hip/ /tmp/gdn_hip_pkg/
COPY patches/gdn_hip_qwen_gdn.patch patches/gdn_hip_state_dtype.patch /tmp/gdn_hip_patches/
RUN set -eu; \
    if [ "$WITH_GDN_HIP" = "1" ]; then \
      . /app/.venv/bin/activate; \
      export PATH="/opt/rocm-7.2.1/lib/llvm/bin:/opt/rocm-7.2.1/bin:${PATH}"; \
      VV=/app/vllm/vllm; \
      MAMBA="$VV"/model_executor/layers/mamba; \
      cp -r /tmp/gdn_hip_pkg "$MAMBA"/gdn_hip; \
      cd "$MAMBA"/gdn_hip; \
        rm -rf build *.egg-info; find . -name '*.so' -delete; find . -name '*_hip.*' -delete; \
        GPU_ARCHS=gfx1201 python setup.py build_ext --inplace; \
        python -c "import torch, glob; torch.ops.load_library(glob.glob('gdn_hip_C*.so')[0]); print('[combined] gdn_hip kernel build + load OK')"; \
      cd /app/vllm; \
        patch -p1 < /tmp/gdn_hip_patches/gdn_hip_qwen_gdn.patch; \
        patch -p1 < /tmp/gdn_hip_patches/gdn_hip_state_dtype.patch; \
      python -c 'import ast; [ast.parse(open(f).read()) for f in ["/app/vllm/vllm/model_executor/layers/mamba/gdn/qwen_gdn_linear_attn.py", "/app/vllm/vllm/model_executor/layers/mamba/mamba_utils.py"]]; print("[combined] gdn_hip overlay + patched files parse OK")'; \
      echo "[combined] gdn_hip applied (set VLLM_GDN_HIP=1 at runtime to engage; default off)"; \
    else echo "[combined] gdn_hip slot present but disabled (build --build-arg WITH_GDN_HIP=1 to enable)"; fi; \
    rm -rf /tmp/gdn_hip_pkg /tmp/gdn_hip_patches

# Entry point inherited from the base (its tuned-attention vLLM launcher: `vllm serve "$@"`).
