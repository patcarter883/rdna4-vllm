# syntax=docker/dockerfile:1
#
# Old vLLM stack (patcarter883 TheRock build: stock vLLM 0.22.0, rocm_attn default, UNTUNED
# attention) + a FRESH canonical W4A8 kernel. This is the A/B partner to vllm22-w4a8:combined:
# same kernel + same models, old vs new attention base, so deltas attribute to the
# collaborator's tuned triton_attn + autotuning + fp8-KV native path.
#
# Build (no GPU — cross-compiles):
#   docker build -f Dockerfile.oldvllm -t vllm-gfx1201-w4a8:fresh \
#     --build-context w4a8_src=/home/pat/code/vllm-rocm714-gfx1250/vllm/csrc/quantization/w4a8_fp8_wmma .
#
# The base already carries our patches/moe_wna16.py tp_size fix, so no source patch is needed.

ARG BASE_IMAGE=vllm-gfx1201:latest
FROM ${BASE_IMAGE}

ENV GPU_ARCHS=gfx1201

# Build the SAME canonical kernel as the combined image, against TheRock ROCm 7.14 / torch.
# --force-reinstall overwrites the kernel the base already had. ld.lld is in _rocm_sdk_core;
# hipcc + llvm in _rocm_sdk_devel. Remove the source after install (import-shadow trap).
COPY --from=w4a8_src . /opt/w4a8_canonical
RUN set -eu; \
    R=/opt/python/lib/python3.12/site-packages/_rocm_sdk_devel; \
    C=/opt/python/lib/python3.12/site-packages/_rocm_sdk_core; \
    export ROCM_HOME="$R" GPU_ARCHS=gfx1201 MAX_JOBS=8 \
           PATH="$C/lib/llvm/bin:$R/lib/llvm/bin:$R/bin:/opt/python/bin:$PATH"; \
    cd /opt/w4a8_canonical; rm -rf build *.egg-info; find . -name '*.so' -delete; \
    pip install . --no-build-isolation --no-deps --force-reinstall; \
    cd /; rm -rf /opt/w4a8_canonical; \
    python3 -c "import w4a8_fp8_wmma, w4a8_fp8_wmma._C; print('[oldvllm] W4A8 import OK')"

ENV VLLM_ROCM_USE_W4A8_FP8_WMMA=1 \
    VLLM_ROCM_W4A8_FP8_WMMA_MOE=1 \
    VLLM_ROCM_W4A8_FP8_WMMA_MOE_VERSION=6
