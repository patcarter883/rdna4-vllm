# Copy to .env and fill in. Only HF_HOME is strictly required; everything else
# has a working default. See README.md for the full walkthrough.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Absolute host path to your HuggingFace cache. Must contain a hub/ subdir with
# the model snapshot already fetched (see README "Quick start"):
#   HF_HOME=/data/hf hf download cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
HF_HOME=/absolute/path/to/hf-cache

# HuggingFace read token — only used by `hf download` at cache-fill time (the
# container runs with HF_HUB_OFFLINE=1). Needed if a model resolves through a
# gated base card. Mint one at https://huggingface.co/settings/tokens .
HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Image / build (Dockerfile.combined, FROM tcclaviger/vllm22:dev)
# ---------------------------------------------------------------------------
# The W4A8 kernel is built into the image from the in-repo w4a8_fp8_wmma/ source
# (always — it's a runtime no-op unless USE_W4A8=1 below). Override the base image
# (the collaborator's tuned-attention vLLM 0.22.69) only if you have a newer tag:
#COMBINED_BASE_IMAGE=tcclaviger/vllm22:dev

# Apply heterogeneous-TP 64:56 sharding at build time. Needs the re-targeted patch in
# patches/het_tp_vllm.patch (see patches/HET_TP_HANDOFF.md). 0 = off (default).
#WITH_HET_TP=0

# ---------------------------------------------------------------------------
# Serving (shared)
# ---------------------------------------------------------------------------
VLLM_HOST_PORT=8000

# Persistent caches (default to repo-local dirs). The Triton cache is the
# important one — it saves the 15-30 min cold FLA-GDN compile on every reboot.
#VLLM_HOST_TRITON_CACHE=/absolute/path/to/triton-cache

# ---------------------------------------------------------------------------
# serve profile (TP=2) — `docker compose --profile serve up`
# ---------------------------------------------------------------------------
# Runtime W4A8 toggle: 1 = W4A8 kernel on, 0 = pure tuned-attention baseline (A/B).
#USE_W4A8=1
# The proven model. MoE: all 35B params resident (~23 GiB) even though ~3B are
# active per token, so it needs BOTH 16 GB cards (TP=2); it cannot run on one.
VLLM_MODEL_ID=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit

# Baseline (stock kernels) memory/context.
VLLM_GPU_MEMORY_UTIL=0.90
VLLM_MAX_MODEL_LEN=8192

# W4A8 profile — these LOW caps are mandatory (the MoE apply scratch OOMs the KV
# cache at the 8192 profiling batch on a 16 GB card). Do not raise blindly.
VLLM_W4A8_GPU_MEMORY_UTIL=0.92
VLLM_W4A8_MAX_MODEL_LEN=2048
VLLM_W4A8_MAX_NUM_BATCHED_TOKENS=2048

# ---------------------------------------------------------------------------
# single profile (one GPU)
# ---------------------------------------------------------------------------
# Which discrete card: 0 = RX 9070 XT (64 CU), 1 = RX 9070 (56 CU).
SINGLE_GPU_INDEX=0
# 35B won't fit 16 GB; default to a small AWQ MoE that does.
SINGLE_MODEL_ID=cyankiwi/Mellum2-12B-A2.5B-Instruct-AWQ-INT4
VLLM_SINGLE_MAX_MODEL_LEN=4096

# ---------------------------------------------------------------------------
# ZAYA1-8B + CCA (`zaya` profile of the main compose) —
#   `docker compose --profile zaya up --build`. Served by the SAME combined image
#   (baked in via WITH_ZAYA=1 below). TP=1, one card. Add --profile rsa for the
#   test-time-compute proxy.
# ---------------------------------------------------------------------------
# Build a leaner W4A8-only image (skip the CCA kernel) with WITH_ZAYA=0.
#WITH_ZAYA=1
# Host dir holding local ZAYA checkpoints (mounted read-only at /models). The
# FP8 weights are built by quant/quantize_fp8.py -> ZAYA1-8B-fp8.
#ZAYA_MODELS_DIR=~/models
#ZAYA_MODEL_ID=/models/ZAYA1-8B-fp8
# Which physical card the single-GPU ZAYA serve uses.
#ZAYA_GPU=0
#ZAYA_HOST_PORT=8001
# Fused CCA kernels (decode + prefill/mixed). Default ON — GPU-validated coherent,
# bit-exact, +38-49% decode tok/s vs eager (docs/zaya/cca-kernel-perf.md). 0 = eager.
#ZAYA_CCA_HIP=1
#ZAYA_CCA_HIP_PREFILL=1
# RSA test-time-compute proxy (`--profile rsa`, no GPU, OpenAI-compatible on :8100).
#RSA_HOST_PORT=8100
#RSA_N=16
#RSA_K=4
#RSA_T=2
