# syntax=docker/dockerfile:1
#
# ZAYA1-8B + CCA support, layered ON TOP of the combined image as a DERIVED image
# (`FROM vllm22-w4a8:combined`) rather than a `--build-arg WITH_ZAYA=1` slot inside
# Dockerfile.combined. Why derived, not a gate:
#   - It adds zero weight/risk to the base combined image (W4A8 + het-TP + tuned
#     attention) — non-ZAYA serving is untouched.
#   - At the time this landed, Dockerfile.combined was being refactored in a
#     parallel session; a derived image avoids editing a file mid-rewrite (the
#     Act IX "wrong-tree" lesson). Folding this into Dockerfile.combined as a
#     gated WITH_ZAYA step later is mechanical — see zaya/ZAYA_HANDOFF.md.
#
# ZAYA1 is a hybrid CCA+MoE model. Support = three pieces, mirroring how W4A8 and
# het-TP are wired (overlay onto the editable /app/vllm + an in-image kernel build
# + surgical registration hooks):
#   (a) NEW model/config/parser/backend files copied onto /app/vllm/vllm,
#   (b) the fused CCA decode HIP kernel built IN-IMAGE from its canonical csrc
#       (cross-compiles for gfx1201 — NO GPU needed, like W4A8),
#   (c) ~9 additive registration hooks (zaya/zaya_vllm_0.22.69.patch), re-targeted
#       to 0.22.69 and dry-run-validated.
#
# Build (no GPU needed):
#   docker build -f Dockerfile.zaya -t vllm22-zaya:combined \
#     --build-arg BASE_IMAGE=vllm22-w4a8:combined .
# Run: docker compose -f docker-compose.zaya.yml --profile zaya up   (see that file)
# Toggle the fused kernel at runtime (no rebuild): ZAYA_CCA_HIP=0 -> eager CCA.

ARG BASE_IMAGE=vllm22-w4a8:combined
FROM ${BASE_IMAGE}

# Re-scope BASE_IMAGE into this build stage so it substitutes in the RUN below
# (an ARG declared before FROM is out of scope after it; with `set -u` an
# unsubstituted ${BASE_IMAGE} aborts the layer).
ARG BASE_IMAGE
ARG GPU_ARCHS=gfx1201
ENV ROCM_HOME=/opt/rocm-7.2.1 \
    GPU_ARCHS=${GPU_ARCHS} \
    MAX_JOBS=8 \
    ZAYA_CCA_HIP=1

# Everything ZAYA in one context dir; removed after the layer is built.
COPY zaya/ /tmp/zaya/
RUN set -eu; \
    . /app/.venv/bin/activate; \
    export PATH="/opt/rocm-7.2.1/lib/llvm/bin:/opt/rocm-7.2.1/bin:${PATH}"; \
    VV=/app/vllm/vllm; \
    # (a) drop the NEW ZAYA overlay files onto the editable vLLM tree.
    cp -r /tmp/zaya/overlay/vllm/. "$VV"/; \
    # (b) CCA decode kernel: build in-image from the canonical csrc. Clean any
    #     host build/ + *.so + hipify artifacts first (ABI binds to THIS image's
    #     torch; a stale gfx1201/ROCm-7.14 .so must not be reused — the W4A8
    #     single-source-of-truth lesson). GPU_ARCHS keeps offload off the iGPU.
    cp -r /tmp/zaya/cca_hip "$VV"/model_executor/layers/mamba/; \
    cd "$VV"/model_executor/layers/mamba/cca_hip; \
      rm -rf build *.egg-info; find . -name '*.so' -delete; find . -name '*_hip.*' -delete; \
      GPU_ARCHS=gfx1201 python setup.py build_ext --inplace; \
      python -c "import torch, glob; torch.ops.load_library(glob.glob('zaya_cca_C*.so')[0]); print('[zaya] CCA kernel build + load OK')"; \
    # (c) additive registration hooks (model/config/parser/backend + splitting_op
    #     + torch.compile-safe MoE-config lookup), re-derived for 0.22.69.
    cd /app/vllm; patch -p1 < /tmp/zaya/zaya_vllm_0.22.69.patch; \
    # CPU sanity: every touched python file parses (full import + registry
    # resolution is the GPU-window coherence gate, see zaya/ZAYA_HANDOFF.md).
    # NB: python -c one-liner, NOT a RUN heredoc — a `<<'PY'` heredoc inside this
    # backslash-continued RUN trips BuildKit ("unterminated heredoc").
    python -c 'import ast; roots=["/app/vllm/vllm/model_executor/models/zaya.py", "/app/vllm/vllm/model_executor/layers/mamba/cca.py", "/app/vllm/vllm/model_executor/layers/mamba/mamba_utils.py", "/app/vllm/vllm/config/model.py", "/app/vllm/vllm/model_executor/layers/fused_moe/fused_moe.py"]; [ast.parse(open(f).read()) for f in roots]; print("[zaya] overlay + patched files parse OK")'; \
    rm -rf /tmp/zaya; \
    echo "[zaya] ZAYA1-8B + CCA support layered on ${BASE_IMAGE}"

# Entry point inherited from the base (its tuned-attention vLLM launcher:
# `vllm serve "$@"`), so docker-compose.zaya.yml's command is JUST serve args.
