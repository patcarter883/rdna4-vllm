{
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["vllm", "spec-decode", "dflash"],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "vllm-prometheus" },
        "definition": "label_values(vllm:num_requests_running, model_name)",
        "query": { "qryType": 1, "query": "label_values(vllm:num_requests_running, model_name)", "refId": "A" },
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "vLLM Serving + Spec Decode (DFlash)",
  "uid": "vllm-serving",
  "version": 1,
  "weekStart": "",
  "panels": [
    { "id": 1, "type": "row", "title": "Overview", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },

    { "id": 2, "type": "stat", "title": "Requests running", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 2 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(vllm:num_requests_running{model_name=~\"$model\"})" } ] },

    { "id": 3, "type": "stat", "title": "Requests waiting (queue)", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\"})" } ] },

    { "id": 4, "type": "stat", "title": "KV cache usage", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "max(vllm:kv_cache_usage_perc{model_name=~\"$model\"}) * 100" } ] },

    { "id": 5, "type": "stat", "title": "Generation tok/s", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:generation_tokens_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 6, "type": "stat", "title": "Preemptions/s", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.01 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:num_preemptions_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 7, "type": "stat", "title": "Completed req/s", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:request_success_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 10, "type": "row", "title": "Spec Decode (DFlash)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": [] },

    { "id": 11, "type": "stat", "title": "Mean acceptance length (tok/step)", "description": "1 + accepted/drafts. 1.0 = no speedup; higher = more target steps skipped per draft.", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 5, "w": 6, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "min": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 1.5 }, { "color": "green", "value": 2.5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "1 + sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval])) / sum(rate(vllm:spec_decode_num_drafts_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 12, "type": "stat", "title": "Draft acceptance rate", "description": "accepted draft tokens / drafted tokens. Fraction of speculated tokens the target kept.", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 5, "w": 6, "x": 6, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 20 }, { "color": "green", "value": 35 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "100 * sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval])) / sum(rate(vllm:spec_decode_num_draft_tokens_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 13, "type": "stat", "title": "Drafts/s", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:spec_decode_num_drafts_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 14, "type": "stat", "title": "Accepted draft tok/s", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval]))" } ] },

    { "id": 15, "type": "timeseries", "title": "Per-position draft acceptance rate", "description": "Per spec position, accepted/drafts. Shows how deep into the draft the target keeps accepting (the DFlash diffusion tail).", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum by (position) (rate(vllm:spec_decode_num_accepted_tokens_per_pos_total{model_name=~\"$model\"}[$__rate_interval])) / scalar(sum(rate(vllm:spec_decode_num_drafts_total{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "pos {{position}}" } ] },

    { "id": 16, "type": "timeseries", "title": "Drafted vs accepted throughput", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 15, "showPoints": "never", "lineWidth": 2, "axisLabel": "tok/s" } }, "overrides": [ { "matcher": { "id": "byName", "options": "accepted tok/s" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }, { "matcher": { "id": "byName", "options": "drafted tok/s" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:spec_decode_num_draft_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "drafted tok/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "accepted tok/s" }
      ] },

    { "id": 17, "type": "timeseries", "title": "Mean acceptance length over time", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "1 + sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval])) / sum(rate(vllm:spec_decode_num_drafts_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "mean accept len" } ] },

    { "id": 18, "type": "timeseries", "title": "Draft acceptance rate over time", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "100 * sum(rate(vllm:spec_decode_num_accepted_tokens_total{model_name=~\"$model\"}[$__rate_interval])) / sum(rate(vllm:spec_decode_num_draft_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "acceptance %" } ] },

    { "id": 20, "type": "row", "title": "Throughput & Load", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }, "panels": [] },

    { "id": 21, "type": "timeseries", "title": "Token throughput", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 15, "showPoints": "never", "lineWidth": 2, "axisLabel": "tok/s" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:prompt_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "prompt tok/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:generation_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "generation tok/s" }
      ] },

    { "id": 22, "type": "timeseries", "title": "Requests running / waiting", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "showPoints": "never", "lineWidth": 2, "stacking": { "mode": "none" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(vllm:num_requests_running{model_name=~\"$model\"})", "legendFormat": "running" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\"})", "legendFormat": "waiting" }
      ] },

    { "id": 30, "type": "row", "title": "Latency", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "panels": [] },

    { "id": 31, "type": "timeseries", "title": "Time to first token (TTFT)", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" }
      ] },

    { "id": 32, "type": "timeseries", "title": "Inter-token latency (ITL)", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" }
      ] },

    { "id": 33, "type": "timeseries", "title": "End-to-end request latency", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" }
      ] },

    { "id": 40, "type": "row", "title": "KV & Prefix Cache", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 }, "panels": [] },

    { "id": 41, "type": "timeseries", "title": "KV cache usage", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 43 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "vllm:kv_cache_usage_perc{model_name=~\"$model\"} * 100", "legendFormat": "{{model_name}} :{{serve_port}}" } ] },

    { "id": 42, "type": "timeseries", "title": "Prefix cache hit rate", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 43 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "vllm-prometheus" }, "expr": "sum(rate(vllm:prefix_cache_hits_total{model_name=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(vllm:prefix_cache_queries_total{model_name=~\"$model\"}[$__rate_interval])), 1)", "legendFormat": "hit rate" } ] }
  ]
}
